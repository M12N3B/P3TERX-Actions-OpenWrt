# Target System Configuration (Phicomm K2P)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_phicomm_k2p=y

# Global Build Settings
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_CCACHE=y
CONFIG_TARGET_OPTIONS=y

# 核心网络基础（解决 dnsmasq 冲突）
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y

# LuCI 界面基础
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# SSR Plus+ 科学上网及其核心组件
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_kmod-tun=y

# ！！！彻底关闭导致云编译报错的 KMS 激活组件 ！！！
# CONFIG_PACKAGE_vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set

# K2P 闪存优化：使用精简版 WiFi 认证组件（极大缩减体积，支持 WPA2/WPA3）
# CONFIG_PACKAGE_wpad-openssl is not set
CONFIG_PACKAGE_wpad-basic-openssl=y

# 网络与系统必备工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# 常用且轻量化的 LuCI 插件
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-ttyd=y

# K2P 没有 USB 接口，强制关闭相关驱动以省出宝贵的空间
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb3=n

# 移除极占空间的 HTTPS 证书与大体积 SSL 库（SSR Plus+ 自身有加密支持，无需重复安装）
CONFIG_PACKAGE_luci-ssl=n
CONFIG_PACKAGE_px5g-mbedtls=n

# 文件系统与精简策略
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_PACKAGE_odhcpd-ipv6only=n
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=n
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_ppp-mod-pppoe=n
CONFIG_PACKAGE_kmod-usb-printer=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_samba4-server=n

# 编译体积极致压缩优化
CONFIG_USE_MKLIBS=y
CONFIG_USE_SSTRIP=y
