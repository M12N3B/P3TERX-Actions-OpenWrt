# ==========================================
# Target System Configuration (小米 AX3000T 專用)
# ==========================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t=y

# 💡 提示：如果你刷了第三方不鎖頭的 U-Boot Mod，請把上面最後一行刪除，改用下面這行：
# CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t-ubootmod=y

# Global Build Settings
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_CCACHE=y
CONFIG_TARGET_OPTIONS=y

# ==========================================
# 核心網路與基礎組件（AX3000T 正常配置）
# ==========================================
# 解決 dnsmasq 衝突
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y

# 寬帶撥號與 IPv6 支持
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y

# Wi-Fi 6 完整無線組件
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic-openssl is not set

# 恢復系統必備的 HTTPS 安全憑證支持（OpenClash 下載訂閱、核心必備）
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_ca-bundle=y

# ==========================================
# LuCI 界面與科學上網插件 (改用 OpenClash)
# ==========================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 1. 移除舊的 SSR Plus+
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn is not set

# 2. 加入 OpenClash 主程式
CONFIG_PACKAGE_luci-app-openclash=y

# 3. OpenClash 必備的核心依賴組件（缺少這些雲編譯會失敗，或裝好後無法運行）
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y

# ==========================================
# 常用網路與系統工具
# ==========================================
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-ttyd=y

# ==========================================
# 移除不需要的硬體驅動（AX3000T 沒有外置 USB）
# ==========================================
CONFIG_PACKAGE_kmod-usb-storage=n
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-usb-core=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-printer=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_samba4-server=n

# ==========================================
# 編譯優化
# ==========================================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_USE_MKLIBS=y
CONFIG_USE_SSTRIP=y
